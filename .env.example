# Required in every environment. Generate a long random value and keep it out of Git.
FSCHP_SECRET_KEY=

# Comma-separated frontend origins that may call the API.
FSCHP_CORS_ORIGINS=http://localhost:8000
FSCHP_ENV=development
FSCHP_COOKIE_SECURE=false
FSCHP_COOKIE_SAMESITE=lax

# Optional: JWT lifetime in minutes.
FSCHP_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: move the SQLite database outside the repo in production.
FSCHP_DB_PATH=./nenep.db

# Optional: create the first admin only when the users table is empty.
FSCHP_BOOTSTRAP_ADMIN_USERNAME=
FSCHP_BOOTSTRAP_ADMIN_PASSWORD=
FSCHP_BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator

# Optional but required if non-admin users can overwrite files after 24h.
# Generate with: python tools/hash_password.py
FSCHP_OVERRIDE_PASSWORD_HASH=
